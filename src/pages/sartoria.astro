---
import BaseLayout from '../layouts/BaseLayout.astro';
import ScrollAtelier from '../components/elements/ScrollAtelier.astro';
import ServicePanel from '../components/elements/ServicePanel.astro';

const services = [
  {
    num: '01',
    title: 'Abito su misura',
    desc: 'Cerimonia, giornaliero, occasione. Prima prova, rifinitura, consegna. Tecnica sartoriale italiana.',
  },
  {
    num: '02',
    title: 'Modifiche sartoriali',
    desc: 'Adattamenti, orli, rimodellamento capi esistenti. Ridisegnare la vestibilità.',
  },
  {
    num: '03',
    title: 'Restauro capi',
    desc: 'Riparazione e reinterpretazione di capi vintage, storici o ereditati. Ogni pezzo ritrova una vita.',
  },
  {
    num: '04',
    title: 'Consulenza tessuti',
    desc: 'Scelta del tessuto giusto per l\u2019occasione, il corpo, la palette. Lana, seta, lino, cotone, mischiati con criterio.',
  },
];
---

<BaseLayout
  reality="sartoria"
  title="Chiara Bassetti — Sartoria su misura"
  description="Sartoria su misura a Torino. Abiti cuciti a mano, modifiche sartoriali, restauro di capi vintage."
>
  <!-- ========== SCROLL-SCRUBBED ATELIER HERO ==========
       The first 4 viewport-heights of the sartoria page are a cinematic
       scroll-scrubbed walk into the atelier. Frames are 1440px JPEGs
       (prefetched from the immagine page) rendered to a canvas. Hotspots
       appear on specific pieces (wardrobe, mannequin, fabric table,
       vintage gown) and clicking opens a side panel with the service
       content. After the scroll sequence, normal content resumes below. -->
  <ScrollAtelier />

  <!-- ========== CONTENT COLUMN ========== -->
  <div class="sart-content">

    <!-- ========== INTRO (hero typography lives on the atelier ceiling now,
         this block is the grounded brief + atelier meta) ========== -->
    <section class="sart-intro" id="hero" data-mannequin-target="hero">
      <p class="sart-hero__brief">
        Cucio abiti su misura con tecnica sartoriale italiana,
        tessuti scelti e dettagli costruiti con te. Atelier a Torino,
        consulenze su appuntamento.
      </p>

      <div class="sart-hero__meta">
        <span class="sart-hero__meta-label">[ ATELIER ]</span>
        <span class="sart-hero__meta-value">Torino · su appuntamento</span>
      </div>
    </section>

    <!-- ========== SERVICES ========== -->
    <section class="sart-services" id="servizi" data-mannequin-target="services">
      <div class="sart-services__head">
        <span class="sart-services__eyebrow">[ COSA CUCIO ]</span>
        <h2 class="sart-services__heading">
          Quattro modi di lavorare la stoffa.
        </h2>
      </div>

      <div class="sart-services__list">
        {services.map((s, i) => (
          <button
            class="sart-svc"
            data-service-idx={i}
            data-service-num={s.num}
            data-mannequin-hover
            type="button"
          >
            <span class="sart-svc__num">{s.num}</span>
            <h3 class="sart-svc__title">{s.title}</h3>
            <p class="sart-svc__desc">{s.desc}</p>
            <span class="sart-svc__arrow" aria-hidden="true">&rarr;</span>
          </button>
        ))}
      </div>
    </section>

    <!-- ========== CTA ========== -->
    <section class="sart-cta" id="contatti" data-mannequin-target="cta">
      <p class="sart-cta__text">
        Prenota una consulenza in atelier.<br />
        Ogni abito su misura inizia da un incontro.
      </p>
      <a href="mailto:hello@chiarabassetti.studio" class="sart-cta__btn" data-mannequin-hover>
        SCRIVIMI &rarr;
      </a>
      <a
        href="https://instagram.com/chiarabassetti.studio"
        target="_blank"
        rel="noopener"
        class="sart-cta__ig"
        data-mannequin-hover
      >@chiarabassetti.studio</a>
    </section>
  </div>

  <!-- Side panel: opens when an atelier hotspot is clicked. Single instance
       reused for all four services. -->
  <ServicePanel />
</BaseLayout>

<script>
  import { initServicePanel, openServicePanel, isServicePanelOpen } from '../scripts/service-panel';
  import { SARTORIA_SERVICES } from '../scripts/service-data';

  // Map atelier hotspot ids to the sartoria service entries.
  const HOTSPOT_TO_SERVICE_IDX: Record<string, number> = {
    abiti:     0, // Abito Su Misura
    modifiche: 1, // Modifiche Sartoriali
    tessuti:   2, // Consulenza Tessuti
    restauro:  3, // Riparazioni / restauro tessile
  };

  let initialized = false;

  document.addEventListener('astro:page-load', () => {
    if (!document.getElementById('svc-panel')) return;

    if (!initialized) {
      initServicePanel();
      initialized = true;
    }

    window.addEventListener('atelier-service-open', ((e: CustomEvent) => {
      if (isServicePanelOpen()) return;
      const id = e.detail?.id as string | undefined;
      if (!id) return;
      const idx = HOTSPOT_TO_SERVICE_IDX[id];
      if (idx === undefined) return;
      const svc = SARTORIA_SERVICES[idx];
      if (!svc) return;
      openServicePanel(svc);
    }) as EventListener);
  });
</script>

<style>
  /* ================= CONTENT COLUMN ================= */
  /* The scroll-scrubbed atelier hero owns the first ~4 viewport heights.
     Afterwards, regular page content flows full-width. */

  .sart-content {
    position: relative;
    z-index: 1;
    width: 100%;
    min-height: 100vh;
    max-width: 1080px;
    margin: 0 auto;
    padding: var(--space-2xl) clamp(2rem, 5vw, 6rem);
  }

  /* ---------------- INTRO (post-atelier brief + meta) ---------------- */
  .sart-intro {
    position: relative;
    padding: clamp(4rem, 10vh, 7rem) clamp(2rem, 4vw, 5rem) var(--space-2xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .sart-hero__brief {
    font-family: var(--font-body);
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--color-fg-muted);
    margin: 0;
    max-width: 520px;
  }

  .sart-hero__meta {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-top: var(--space-xl);
  }

  .sart-hero__meta-label {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-fg-faint);
  }

  .sart-hero__meta-value {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    letter-spacing: 0.05em;
    color: var(--color-fg-muted);
  }

  /* 3D Spline scene fills the whole hero section behind the text. Its
     dark bg matches the page bg so the canvas blends edge-to-edge. */
  .sart-hero__scene {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  /* ---------------- SERVICES ---------------- */
  .sart-services {
    padding: var(--space-2xl) clamp(2rem, 4vw, 5rem);
    border-top: 1px solid var(--color-border);
  }

  .sart-services__head {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    margin-bottom: var(--space-xl);
  }

  .sart-services__eyebrow {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .sart-services__heading {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 1rem + 2.2vw, 3.2rem);
    font-weight: var(--display-weight);
    letter-spacing: 0.01em;
    color: var(--color-fg);
    max-width: 720px;
    margin: 0;
    line-height: 1.1;
  }

  .sart-services__list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* Service tile -- full-width clickable row. Hover state shows the arrow
     reaching right; click dispatches an event the mannequin listens to. */
  .sart-svc {
    border-top: 1px solid var(--color-border);
    padding: var(--space-lg) 0;
    display: grid;
    grid-template-columns: 44px 1fr auto;
    grid-template-rows: auto auto;
    gap: 4px var(--space-md);
    align-items: start;
    cursor: pointer;
    background: transparent;
    border-left: none;
    border-right: none;
    border-bottom: none;
    width: 100%;
    text-align: left;
    color: inherit;
    transition: padding-left 0.4s cubic-bezier(0.22, 1, 0.36, 1),
      background 0.4s ease;
  }
  .sart-svc__num { grid-column: 1; grid-row: 1 / 3; }
  .sart-svc__title { grid-column: 2; grid-row: 1; }
  .sart-svc__desc { grid-column: 2; grid-row: 2; }
  .sart-svc__arrow { grid-column: 3; grid-row: 1 / 3; align-self: center; }

  .sart-svc:last-child {
    border-bottom: 1px solid var(--color-border);
  }

  .sart-svc:hover,
  .sart-svc:focus-visible {
    padding-left: var(--space-sm);
    background: linear-gradient(
      90deg,
      rgba(255, 255, 255, 0.02) 0%,
      transparent 80%
    );
    outline: none;
  }

  .sart-svc__num {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.2em;
    color: var(--color-fg-faint);
    align-self: start;
    padding-top: 6px;
  }

  .sart-svc__title {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 1rem + 1vw, 2rem);
    font-weight: var(--display-weight);
    color: var(--color-fg);
    margin: 0 0 var(--space-xs);
    line-height: 1.1;
  }

  .sart-svc__desc {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    color: var(--color-fg-muted);
    max-width: 520px;
    margin: 0;
  }

  .sart-svc__arrow {
    font-size: 1.25rem;
    color: var(--color-fg-faint);
    transform: translateX(-8px);
    opacity: 0.6;
    transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.4s ease,
      color 0.4s ease;
  }

  .sart-svc:hover .sart-svc__arrow,
  .sart-svc:focus-visible .sart-svc__arrow {
    transform: translateX(0);
    opacity: 1;
    color: var(--color-accent);
  }

  /* ---------------- CTA ---------------- */
  .sart-cta {
    padding: var(--space-2xl) clamp(2rem, 4vw, 5rem) var(--space-xl);
    border-top: 1px solid var(--color-border);
    max-width: 640px;
  }

  .sart-cta__text {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 1rem + 2vw, 2.8rem);
    font-weight: 300;
    line-height: var(--leading-snug);
    color: var(--color-fg);
    margin: 0 0 var(--space-lg);
  }

  .sart-cta__btn {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-fg);
    border: 1px solid var(--color-accent);
    padding: 14px 28px;
    transition: background 0.2s, color 0.2s;
  }

  .sart-cta__btn:hover {
    background: var(--color-accent);
    color: var(--color-bg);
  }

  .sart-cta__ig {
    display: block;
    margin-top: var(--space-md);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    letter-spacing: 0.05em;
    color: var(--color-fg-faint);
    text-decoration: none;
    transition: color 0.2s;
  }

  .sart-cta__ig:hover {
    color: var(--color-accent);
  }

  /* ---------------- MOBILE (deferred -- desktop-first for v1) ---------------- */
  @media (max-width: 900px) {
    /* Scroll-scrubbed hero is rough on touch; we may swap it for a static
       hero image on mobile later. For now it still works, just larger files. */
  }
</style>
