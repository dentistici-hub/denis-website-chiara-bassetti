---
import '@fontsource/cormorant-garamond/300.css';
import '@fontsource/cormorant-garamond/300-italic.css';
import '@fontsource/cormorant-garamond/400.css';
import '@fontsource/cormorant-garamond/400-italic.css';
import '@fontsource-variable/dm-sans';
import '@fontsource-variable/dm-sans/wght-italic.css';
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import SchemaLayer from '../components/seo/SchemaLayer.astro';
import Analytics from '../components/seo/Analytics.astro';
import { site } from '../content/site';

interface Props {
  title: string;
  description: string;
  reality?: 'immagine' | 'sartoria';
  /** Optional OG image path relative to the site root (default: /og-cover.jpg) */
  ogImage?: string;
  /** Content-type hint for social cards -- "website" for root, "article" for blog etc. */
  ogType?: 'website' | 'article';
  /** Set true only on pages that shouldn't be indexed (e.g. staging copies). */
  noindex?: boolean;
}

const {
  title,
  description,
  reality = 'immagine',
  ogImage = 'og-cover.jpg',
  ogType = 'website',
  noindex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(`${import.meta.env.BASE_URL}${ogImage.replace(/^\//, '')}`, Astro.site).toString();
const pageUrlForSchema = canonicalURL.toString();
---

<!doctype html>
<html lang={site.language} class={reality}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={site.founder.name} />
    <meta name="publisher" content={site.name} />
    <meta name="keywords" content={[
      'Chiara Bassetti',
      'image consultant Torino',
      'armocromia Torino',
      'consulenza immagine Torino',
      'sartoria su misura Torino',
      'abiti su misura Torino',
      'modifiche sartoriali Torino',
      'RAH color test',
      'capsula dopaminica',
      'restauro capi vintage',
      'consulenza tessuti',
      'makedresser',
    ].join(', ')} />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large, max-snippet:-1'} />
    <meta name="googlebot" content={noindex ? 'noindex, nofollow' : 'index, follow'} />

    <!-- Local / geo hints -->
    <meta name="geo.region" content={site.geo.region} />
    <meta name="geo.placename" content={site.geo.placename} />
    <meta name="geo.position" content={site.geo.position} />
    <meta name="ICBM" content={site.geo.position.replace(';', ', ')} />

    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" hreflang={site.language} href={canonicalURL} />
    <link rel="alternate" hreflang="x-default" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:locale" content={site.locale} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:alt" content={`${site.name} \u2014 ${site.tagline}`} />

    <!-- Twitter / X card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- Layered JSON-LD (business + person + services + webpage + FAQ) -->
    <SchemaLayer
      pageTitle={title}
      pageDescription={description}
      pageUrl={pageUrlForSchema}
      reality={reality}
    />

    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />

    <!-- Analytics (no-op until env vars are set) -->
    <Analytics />

    <!-- SPA-style client routing so the persistent mannequin survives the
         page swap without being torn down. -->
    <ClientRouter />

    <!-- Persistent mannequin visibility rules + default-hide during entrance.
         The mannequin is always in the DOM (transition:persist) but is only
         visible on the sartoria reality. During a ClientRouter-driven swap
         her node is preserved, so no flicker. -->
    <style is:inline>
      /* Kill the View Transitions API's default cross-fade on root -- our
         custom GSAP choreography handles all timing. Without this, the
         browser overlays a 300ms fade between old and new snapshots on top
         of our animations, causing a visible extra transition. */
      ::view-transition-old(root),
      ::view-transition-new(root) {
        animation: none;
        mix-blend-mode: normal;
      }
    </style>
    <style is:inline>
      /* Pre-hide surrounding content during a transition so it doesn't
         flash in before the entrance choreography runs. */
      html.reality-entering main > *,
      html.reality-entering header,
      html.reality-entering footer {
        visibility: hidden;
      }
    </style>
    <script is:inline>
      if (
        typeof sessionStorage !== 'undefined' &&
        sessionStorage.getItem('reality-transitioning') === '1'
      ) {
        document.documentElement.classList.add('reality-entering');
      }
    </script>

    <!-- Atelier frame prefetch. Runs synchronously as HTML parses, BEFORE
         any JS framework or event handler. Injects 193 <link rel="prefetch">
         tags for the sartoria atelier JPEG sequence. Browsers start
         downloading them with low priority immediately, so by the time the
         user navigates to sartoria the 45MB is already in the HTTP cache.
         Sentinel in sessionStorage prevents re-queueing on every SPA nav. -->
    <script is:inline define:vars={{ BASE: import.meta.env.BASE_URL }}>
      try {
        if (typeof sessionStorage !== 'undefined' && sessionStorage.getItem('atelier-prefetched') !== '1') {
          sessionStorage.setItem('atelier-prefetched', '1');
          var frag = document.createDocumentFragment();
          for (var i = 1; i <= 193; i++) {
            var link = document.createElement('link');
            link.rel = 'prefetch';
            link.as = 'image';
            link.href = BASE + 'scenes/atelier-frames/' + String(i).padStart(4, '0') + '.jpg';
            frag.appendChild(link);
          }
          document.head.appendChild(frag);
        }
      } catch (e) {}
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Vai al contenuto</a>
    <div class="scroll-progress" id="scroll-progress" aria-hidden="true"></div>
    <div class="grain-overlay" aria-hidden="true"></div>
    <!-- Custom cursor -->
    <div class="cursor-dot" aria-hidden="true"></div>
    <div class="cursor-circle" aria-hidden="true"></div>

    <Header />
    <main id="main-content">
      <slot />
    </main>

    <!-- Crawler-friendly semantic fallback. Visible only when CSS/JS fail
         to load, but present in the HTML source so AI crawlers and
         non-JS indexers can still read the business summary + services
         without executing the cinematic front-end. -->
    <noscript>
      <section class="noscript-fallback" aria-label="Riepilogo servizi">
        <h1>{site.name}</h1>
        <p>{site.description}</p>
        <p>Atelier a {site.contact.city}, {site.contact.country} \u2014 su appuntamento.</p>
        <p>Contatti: <a href={`mailto:${site.contact.email}`}>{site.contact.email}</a> \u00b7 <a href={site.contact.instagram}>{site.contact.instagramHandle}</a></p>
      </section>
    </noscript>

    <Footer />


    <script>
      import { initReality } from '../scripts/reality';
      import { initScroll } from '../scripts/scroll';
      import { initCursor } from '../scripts/cursor';

      let lenisInitialized = false;

      // Pre-hide new content the moment a ClientRouter nav starts so nothing
      // flashes in before the entrance choreography runs.
      document.addEventListener('astro:before-preparation', () => {
        document.documentElement.classList.add('reality-entering');
      });

      // astro:page-load fires on initial load AND after every SPA swap.
      document.addEventListener('astro:page-load', async () => {
        // Lenis + cursor are attached to window/document so they only need to
        // initialize once; they survive the page swap.
        if (!lenisInitialized) {
          lenisInitialized = true;
          const lenis = await initScroll();
          (window as any).__lenis = lenis;
          if (lenis) {
            lenis.on('scroll', (e: any) => {
              window.dispatchEvent(new CustomEvent('lenis-scroll', {
                detail: { velocity: e.velocity, direction: e.direction, progress: e.progress }
              }));
            });
          }
          window.addEventListener('lenis-stop', () => lenis?.stop());
          window.addEventListener('lenis-start', () => lenis?.start());
          initCursor();
        }

        // initReality handles the reality-change dispatch, toggle binding,
        // and (on non-first page-loads) the entrance choreography.
        await initReality();
        // Atelier frames are prefetched via inline <link rel="prefetch"> tags
        // in <head> -- no JS fallback needed here.
      });

      // Hide broken <img> tags instead of rendering the browser's default
      // broken-image icon. Asset gaps are still flagged in the console so
      // Denis can see what's missing.
      document.addEventListener('error', (e) => {
        const el = e.target as HTMLElement | null;
        if (el && el.tagName === 'IMG') {
          const img = el as HTMLImageElement;
          img.style.display = 'none';
          if (!img.dataset.errorLogged) {
            console.warn('[chiara] missing image:', img.getAttribute('src'));
            img.dataset.errorLogged = '1';
          }
        }
      }, true);
    </script>
  </body>
</html>
