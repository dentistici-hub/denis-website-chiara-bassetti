---
// Fixed top bar:
// - Left: Chiara Bassetti wordmark (always visible, acts as home link to /)
// - Center: enlarged Immagine / Sartoria dual-reality toggle
// - Right: (empty, reserved for future utility link)
// The toggle dispatches the `toggle-reality` flow handled by reality.ts.
const BASE = import.meta.env.BASE_URL;
---

<header class="header">
  <div class="header__inner">
    <a class="header__brand" href={BASE} aria-label="Chiara Bassetti — home">
      Chiara Bassetti
    </a>

    <button
      class="reality-toggle"
      type="button"
      aria-label="Cambia realtà"
      id="reality-toggle"
    >
      <span class="reality-toggle__opt" data-opt="immagine">Immagine</span>
      <span class="reality-toggle__sep" aria-hidden="true">·</span>
      <span class="reality-toggle__opt" data-opt="sartoria">Sartoria</span>
    </button>

    <span class="header__spacer" aria-hidden="true"></span>
  </div>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: var(--z-header);
    padding: clamp(1rem, 0.8rem + 0.6vw, 1.75rem) clamp(1.5rem, 0.5rem + 2vw, 3rem);
    pointer-events: none;
  }

  .header__inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: var(--space-md);
    max-width: none; /* full-bleed so logo hugs left, spacer matches right */
  }

  /* ---- Brand / logo ---- */
  .header__brand {
    pointer-events: auto;
    justify-self: start;
    font-family: var(--font-display);
    font-size: clamp(1rem, 0.8rem + 0.6vw, 1.4rem);
    font-weight: 400;
    letter-spacing: 0.02em;
    color: var(--color-fg);
    text-decoration: none;
    mix-blend-mode: difference;
    transition: opacity var(--duration-fast) var(--ease-out);
  }

  .header__brand:hover {
    opacity: 0.75;
  }

  /* On sartoria the hero is light-ish (terracotta/pink), on immagine it's
     cream. mix-blend-mode: difference guarantees the logo stays legible
     over both without us hand-tuning colors per reality. */

  /* ---- Dual-reality toggle ---- */
  .reality-toggle {
    pointer-events: auto;
    justify-self: center;
    display: inline-flex;
    align-items: center;
    gap: clamp(10px, 0.5rem + 0.4vw, 18px);
    background: rgba(0, 0, 0, 0.08);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: clamp(10px, 0.5rem + 0.3vw, 14px) clamp(18px, 1rem + 1vw, 28px);
    font-family: var(--font-body);
    font-size: clamp(11px, 10px + 0.1vw, 13px);
    font-weight: 500;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-fg-muted);
    cursor: pointer;
    transition:
      border-color var(--duration-fast) var(--ease-out),
      background-color var(--duration-slow) var(--ease-in-out),
      color var(--duration-fast) var(--ease-out);
  }

  .reality-toggle:hover {
    border-color: var(--color-fg);
    background: rgba(0, 0, 0, 0.14);
  }

  .reality-toggle__opt {
    transition: color var(--duration-fast) var(--ease-out);
    color: var(--color-fg-faint);
  }

  .reality-toggle__opt.is-active {
    color: var(--color-fg);
  }

  .reality-toggle__sep {
    color: var(--color-fg-faint);
    opacity: 0.6;
  }

  .header__spacer {
    /* Keeps the grid balanced so the toggle stays truly centered. */
  }

  @media (max-width: 600px) {
    .header__inner {
      grid-template-columns: auto 1fr auto;
    }
    .reality-toggle {
      font-size: 10px;
      padding: 8px 14px;
      letter-spacing: 0.18em;
      gap: 8px;
    }
  }
</style>
