---
/**
 * Scroll-scrubbed atelier hero.
 *
 * Pre-rendered image sequence (193 frames, 800px wide JPEGs) rendered to a
 * canvas. Scroll position drives the current frame. The video was exported
 * "normal-to-chaos" so we REVERSE it on playback -- scroll=0 shows the
 * chaotic entry state, scroll=1 shows the clean atelier interior.
 *
 * Sticky inside a tall section so the camera scrubs through the space while
 * the viewport stays still (classic "scrollytelling" pattern).
 *
 * Hotspots overlay the canvas at specific scroll ranges; clicking dispatches
 * a custom event that the page's side-panel system listens to.
 */

interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;

// Frame config -- must match the output of the ffmpeg extraction step.
// Frames live at public/scenes/atelier-frames/0001.jpg .. 0193.jpg.
const FRAME_COUNT = 193;
const BASE = import.meta.env.BASE_URL;

// Scroll timeline:
//   0.0 - ANIMATION_END  = video scrubs from START_FRAME -> END_FRAME
//   ANIMATION_END - 1.0  = HOLD zone, canvas stays on END_FRAME
// The hold gives the user time to see the hotspots without needing pixel-
// perfect scroll control. Without it, a fast scroll skips past the payload
// frame entirely.
const START_FRAME = FRAME_COUNT; // 193 -- intro / chaos end
const END_FRAME = 1;             // 1 -- calm "all-services-visible" composition
const ANIMATION_END = 0.65;      // 65% of scroll plays the video, 35% holds

// Hotspots visible during the HOLD zone (after animation completes). Fade
// in as the animation resolves so they don't compete with the motion.
const HOTSPOTS = [
  { id: 'abiti',     service: 'Abito su misura',     from: 0.6, to: 1.0, x: 22, y: 52 },
  { id: 'modifiche', service: 'Modifiche sartoriali', from: 0.6, to: 1.0, x: 42, y: 58 },
  { id: 'tessuti',   service: 'Consulenza tessuti',   from: 0.6, to: 1.0, x: 60, y: 62 },
  { id: 'restauro',  service: 'Restauro capi',        from: 0.6, to: 1.0, x: 78, y: 56 },
];
---

<section class:list={['atelier-hero', className]} data-atelier-hero>
  <div class="atelier-hero__sticky">
    <!-- Canvas-sized frame wrapper -- everything inside scales with it so
         hotspots + loader + progress all anchor to video bounds, not
         viewport bounds. On wide screens the frame shrinks to ~65vh,
         leaving terracotta margins on both sides (reads as framed artwork
         on a wall). On mobile it fills. -->
    <div class="atelier-hero__frame" data-atelier-frame>
      <canvas class="atelier-hero__canvas" data-atelier-canvas></canvas>

      <!-- Loading veil -- covers the canvas until a usable chunk of frames
           have downloaded. -->
      <div class="atelier-loader" data-atelier-loader>
        <div class="atelier-loader__ring"></div>
        <div class="atelier-loader__label">Benvenuti nell'atelier</div>
        <div class="atelier-loader__progress">
          <span class="atelier-loader__bar" data-atelier-loader-bar></span>
        </div>
        <div class="atelier-loader__count" data-atelier-loader-count>0%</div>
      </div>

      <!-- Hotspot overlay layer. Percentage positions anchor to the frame
           (canvas bounds), not the viewport, so they follow the video on
           every screen size. -->
      <div class="atelier-hero__hotspots" data-atelier-hotspots>
        {HOTSPOTS.map((h) => (
          <button
            class="hotspot"
            type="button"
            data-hotspot-id={h.id}
            data-hotspot-from={h.from}
            data-hotspot-to={h.to}
            style={`--hx: ${h.x}%; --hy: ${h.y}%`}
            aria-label={h.service}
          >
            <span class="hotspot__ring"></span>
            <span class="hotspot__dot"></span>
            <span class="hotspot__label">{h.service}</span>
          </button>
        ))}
      </div>

      <!-- Progress indicator -- subtle line at bottom of the frame. -->
      <div class="atelier-hero__progress" data-atelier-progress></div>
    </div>
  </div>
</section>

<script define:vars={{ FRAME_COUNT, BASE, START_FRAME, END_FRAME, ANIMATION_END }}>
  const FRAME_DIR = `${BASE}scenes/atelier-frames/`;
  // Loader hides only when ALL frames are loaded AND at least MIN_LOADER_TIME
  // has elapsed. The 2s floor keeps the "Benvenuti nell'atelier" greeting on
  // screen long enough to read, even when the cached prefetch makes loading
  // nearly instant.
  const MIN_LOADER_TIME = 2000;

  let images = [];
  let ctx = null;
  let canvas = null;
  let section = null;
  let progressEl = null;
  let loaderEl = null;
  let loaderBar = null;
  let loaderCount = null;
  let hotspots = [];
  let loadedCount = 0;
  let loaderHidden = false;
  let loaderStartTime = 0;
  let currentFrame = -1;
  let rafPending = false;
  let scrollListener = null;
  let resizeListener = null;

  function pad4(n) {
    return String(n).padStart(4, '0');
  }

  function sizeCanvas() {
    if (!canvas) return;
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    const w = canvas.clientWidth;
    const h = canvas.clientHeight;
    canvas.width = Math.floor(w * dpr);
    canvas.height = Math.floor(h * dpr);
  }

  function findNearestLoaded(idx) {
    // Return the closest loaded frame to idx. This lets us draw SOMETHING
    // immediately even before the exact frame has finished downloading.
    const img = images[idx];
    if (img && img.complete && img.naturalWidth > 0) return idx;
    for (let r = 1; r < FRAME_COUNT; r++) {
      const a = idx - r;
      const b = idx + r;
      if (a >= 0) {
        const ia = images[a];
        if (ia && ia.complete && ia.naturalWidth > 0) return a;
      }
      if (b < FRAME_COUNT) {
        const ib = images[b];
        if (ib && ib.complete && ib.naturalWidth > 0) return b;
      }
    }
    return -1;
  }

  function drawFrame(idx) {
    if (!ctx || !canvas) return;
    const actualIdx = findNearestLoaded(idx);
    if (actualIdx < 0) return;
    const img = images[actualIdx];
    const cw = canvas.width;
    const ch = canvas.height;
    const iw = img.naturalWidth;
    const ih = img.naturalHeight;
    const canvasRatio = cw / ch;
    const imgRatio = iw / ih;
    let dw, dh, dx, dy;
    if (imgRatio > canvasRatio) {
      dh = ch;
      dw = ch * imgRatio;
      dx = (cw - dw) / 2;
      dy = 0;
    } else {
      dw = cw;
      dh = cw / imgRatio;
      dx = 0;
      dy = (ch - dh) / 2;
    }
    ctx.drawImage(img, dx, dy, dw, dh);
  }

  function computeProgress() {
    if (!section) return 0;
    const rect = section.getBoundingClientRect();
    const vh = window.innerHeight;
    const total = rect.height - vh;
    const scrolled = -rect.top;
    return Math.max(0, Math.min(1, scrolled / total));
  }

  function updateHotspots(progress) {
    for (const h of hotspots) {
      const active = progress >= h.from && progress <= h.to;
      h.el.classList.toggle('is-visible', active);
      // Fade in within first 15% of range, fade out within last 15%
      const range = h.to - h.from;
      const local = (progress - h.from) / range;
      let opacity = 0;
      if (active) {
        if (local < 0.15) opacity = local / 0.15;
        else if (local > 0.85) opacity = (1 - local) / 0.15;
        else opacity = 1;
      }
      h.el.style.opacity = String(opacity);
    }
  }

  function tick() {
    rafPending = false;
    const progress = computeProgress();
    // Animation plays across 0 -> ANIMATION_END. After that, the canvas is
    // pinned on END_FRAME while the user continues scrolling through the
    // hold zone. This prevents users from scrolling past the hotspot view
    // before they can click anything.
    const animProgress = Math.min(progress / ANIMATION_END, 1);
    const startIdx = START_FRAME - 1;
    const endIdx = END_FRAME - 1;
    const frameIdx = Math.round(startIdx + (endIdx - startIdx) * animProgress);
    const safeIdx = Math.max(0, Math.min(FRAME_COUNT - 1, frameIdx));
    if (safeIdx !== currentFrame) {
      drawFrame(safeIdx);
      currentFrame = safeIdx;
    }
    updateHotspots(progress);
    if (progressEl) {
      progressEl.style.transform = `scaleX(${progress})`;
    }
  }

  function onScroll() {
    if (rafPending) return;
    rafPending = true;
    requestAnimationFrame(tick);
  }

  function updateLoader() {
    if (!loaderBar || !loaderCount) return;
    const pct = Math.min(100, Math.round((loadedCount / FRAME_COUNT) * 100));
    loaderBar.style.transform = `scaleX(${pct / 100})`;
    loaderCount.textContent = pct + '%';
  }

  function maybeHideLoader() {
    if (loaderHidden || !loaderEl) return;
    const elapsed = performance.now() - loaderStartTime;
    const loadingDone = loadedCount >= FRAME_COUNT;
    if (!loadingDone || elapsed < MIN_LOADER_TIME) return;

    sizeCanvas();
    currentFrame = -1;
    tick();

    loaderHidden = true;
    loaderEl.classList.add('is-hiding');
    setTimeout(() => {
      if (loaderEl) loaderEl.style.display = 'none';
    }, 800);
  }

  function preload() {
    images = new Array(FRAME_COUNT);
    // Priority order:
    //   1. The START frame (what scroll=0 shows) -- for instant first paint
    //   2. The END frame region (hotspot composition)
    //   3. Fill in the gap between them
    //   4. Everything else
    const order = [];
    const startIdx = START_FRAME - 1;
    const endIdx = END_FRAME - 1;
    const priorityStart = Math.max(0, endIdx - 5);
    const priorityEnd = Math.min(FRAME_COUNT, endIdx + 5);

    order.push(startIdx); // 1. starting frame first
    for (let i = priorityStart; i < priorityEnd; i++) order.push(i); // 2. end zone
    // 3. Fill interior between start and end (reverse-iterating from
    //    startIdx down toward endIdx skips work since we already queued
    //    start/end regions).
    const lo = Math.min(startIdx, endIdx);
    const hi = Math.max(startIdx, endIdx);
    for (let i = hi - 1; i > lo; i--) {
      if (!order.includes(i)) order.push(i);
    }
    // 4. Everything else
    for (let i = 0; i < FRAME_COUNT; i++) {
      if (!order.includes(i)) order.push(i);
    }

    for (const i of order) {
      const img = new Image();
      let counted = false;
      // Idempotent load handler -- counts at most once per image regardless
      // of whether real onload fires, synthetic dispatch fires, or both.
      // Cached images from the prefetch can fire load synchronously once
      // src is set, racing our handler attachment.
      const onLoad = () => {
        if (counted) return;
        counted = true;
        loadedCount++;
        updateLoader();
        tick();
        maybeHideLoader();
      };
      const onErr = () => {
        if (counted) return;
        counted = true;
        loadedCount++;
        updateLoader();
        maybeHideLoader();
      };
      img.onload = onLoad;
      img.onerror = onErr;
      img.decoding = 'async';
      img.src = `${FRAME_DIR}${pad4(i + 1)}.jpg`;
      if (img.complete && img.naturalWidth > 0) {
        Promise.resolve().then(onLoad);
      }
      images[i] = img;
    }
  }

  function init() {
    section = document.querySelector('[data-atelier-hero]');
    canvas = document.querySelector('[data-atelier-canvas]');
    progressEl = document.querySelector('[data-atelier-progress]');
    loaderEl = document.querySelector('[data-atelier-loader]');
    loaderBar = document.querySelector('[data-atelier-loader-bar]');
    loaderCount = document.querySelector('[data-atelier-loader-count]');
    if (!section || !canvas) return;

    loaderStartTime = performance.now();
    setTimeout(maybeHideLoader, MIN_LOADER_TIME + 50);

    ctx = canvas.getContext('2d');
    sizeCanvas();

    // Collect hotspots into a friendly data shape
    hotspots = Array.from(
      document.querySelectorAll('[data-hotspot-id]'),
    ).map((el) => ({
      el,
      id: el.dataset.hotspotId,
      from: parseFloat(el.dataset.hotspotFrom),
      to: parseFloat(el.dataset.hotspotTo),
    }));

    // Click -> dispatch custom event for side-panel system
    for (const h of hotspots) {
      h.el.addEventListener('click', () => {
        window.dispatchEvent(
          new CustomEvent('atelier-service-open', { detail: { id: h.id } }),
        );
      });
    }

    preload();

    scrollListener = onScroll;
    resizeListener = () => {
      sizeCanvas();
      currentFrame = -1; // force redraw at new size
      tick();
    };
    window.addEventListener('scroll', scrollListener, { passive: true });
    window.addEventListener('resize', resizeListener, { passive: true });

    tick();
  }

  function teardown() {
    if (scrollListener) window.removeEventListener('scroll', scrollListener);
    if (resizeListener) window.removeEventListener('resize', resizeListener);
    images = [];
    ctx = null;
    canvas = null;
    section = null;
    hotspots = [];
    loadedCount = 0;
    currentFrame = -1;
  }

  document.addEventListener('astro:page-load', () => {
    if (document.querySelector('[data-atelier-hero]')) {
      init();
    } else {
      teardown();
    }
  });

  document.addEventListener('astro:before-swap', () => {
    teardown();
  });

  if (document.readyState === 'complete' && document.querySelector('[data-atelier-hero]')) {
    init();
  }
</script>

<style>
  .atelier-hero {
    /* Section is 300vh: ~195vh (65%) for animation scrub, ~105vh (35%)
       for the HOLD zone where the canvas stays on the final frame and
       hotspots are fully visible. The hold zone is the "stop" Denis
       asked for -- ensures users can't blast past the interactive view. */
    position: relative;
    height: 300vh;
    width: 100%;
    background: #BC9181;
  }

  .atelier-hero__sticky {
    position: sticky;
    top: 0;
    width: 100%;
    height: 100vh;
    height: 100svh;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #BC9181;
  }

  /* Frame fills the viewport completely. drawFrame uses cover logic:
     whichever image dimension is smaller relative to canvas gets scaled
     up to fit, the other gets cropped. On a landscape desktop viewport
     with our 9:16 portrait source, this fits WIDTH and crops some from
     top + bottom (the atelier is centered vertically in the source so
     key content stays in view). On mobile portrait, it's a natural 1:1
     fit with no crop. No terracotta margins on any screen. */
  .atelier-hero__frame {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .atelier-hero__canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }

  /* ---- Hotspots ---- */
  .atelier-hero__hotspots {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hotspot {
    position: absolute;
    left: var(--hx);
    top: var(--hy);
    transform: translate(-50%, -50%);
    width: 44px;
    height: 44px;
    background: transparent;
    border: none;
    cursor: pointer;
    pointer-events: auto;
    padding: 0;
    opacity: 0;
    transition: opacity 0.4s ease;
    will-change: opacity;
  }

  .hotspot.is-visible {
    pointer-events: auto;
  }

  .hotspot:not(.is-visible) {
    pointer-events: none;
  }

  .hotspot__ring {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 1px solid rgba(255, 240, 220, 0.7);
    animation: hotspot-pulse 2.5s ease-in-out infinite;
  }

  .hotspot__dot {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: rgba(255, 240, 220, 0.95);
    transform: translate(-50%, -50%);
    box-shadow: 0 0 12px rgba(255, 200, 150, 0.7);
  }

  .hotspot__label {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(6px);
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255, 240, 220, 0.95);
    white-space: nowrap;
    text-shadow: 0 1px 12px rgba(0, 0, 0, 0.6);
    padding: 4px 8px;
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }

  .hotspot:hover .hotspot__label,
  .hotspot:focus-visible .hotspot__label {
    opacity: 1;
  }

  .hotspot:hover .hotspot__dot,
  .hotspot:focus-visible .hotspot__dot {
    background: rgba(255, 210, 170, 1);
    box-shadow: 0 0 20px rgba(255, 180, 130, 0.9);
  }

  @keyframes hotspot-pulse {
    0%, 100% {
      transform: scale(1);
      opacity: 0.7;
    }
    50% {
      transform: scale(1.35);
      opacity: 0;
    }
  }

  /* ---- Progress bar ---- */
  .atelier-hero__progress {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 2px;
    background: rgba(255, 240, 220, 0.5);
    transform-origin: left center;
    transform: scaleX(0);
    will-change: transform;
  }

  /* ---- Loader veil ---- */
  .atelier-loader {
    position: absolute;
    inset: 0;
    background: #BC9181;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 24px;
    z-index: 20;
    transition: opacity 0.8s ease, visibility 0.8s ease;
  }

  .atelier-loader.is-hiding {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  .atelier-loader__ring {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: 1px solid rgba(248, 240, 232, 0.8);
    border-top-color: transparent;
    animation: atelier-spin 1.4s linear infinite;
  }

  .atelier-loader__label {
    font-family: var(--font-display);
    font-size: clamp(1rem, 0.8rem + 0.6vw, 1.25rem);
    font-weight: 300;
    letter-spacing: 0.04em;
    color: rgba(248, 240, 232, 0.95);
    font-style: italic;
  }

  .atelier-loader__progress {
    width: min(280px, 40vw);
    height: 1px;
    background: rgba(248, 240, 232, 0.2);
    overflow: hidden;
  }

  .atelier-loader__bar {
    display: block;
    width: 100%;
    height: 100%;
    background: rgba(248, 240, 232, 0.9);
    transform-origin: left center;
    transform: scaleX(0);
    transition: transform 0.2s ease-out;
  }

  .atelier-loader__count {
    font-family: var(--font-body);
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(248, 240, 232, 0.7);
  }

  @keyframes atelier-spin {
    to { transform: rotate(360deg); }
  }
</style>
