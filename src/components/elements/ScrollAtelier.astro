---
/**
 * Scroll-scrubbed atelier hero.
 *
 * Pre-rendered image sequence (193 frames, 800px wide JPEGs) rendered to a
 * canvas. Scroll position drives the current frame. The video was exported
 * "normal-to-chaos" so we REVERSE it on playback -- scroll=0 shows the
 * chaotic entry state, scroll=1 shows the clean atelier interior.
 *
 * Sticky inside a tall section so the camera scrubs through the space while
 * the viewport stays still (classic "scrollytelling" pattern).
 *
 * Hotspots overlay the canvas at specific scroll ranges; clicking dispatches
 * a custom event that the page's side-panel system listens to.
 */

interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;

// Frame config -- must match the output of the ffmpeg extraction step.
// Frames live at public/scenes/atelier-frames/0001.jpg .. 0193.jpg.
const FRAME_COUNT = 193;
const BASE = import.meta.env.BASE_URL;

// Hotspots -- each is clickable within a scroll-progress range (0..1).
// Position in screen space as percentages. Tune after first visual check.
const HOTSPOTS = [
  { id: 'abiti', service: 'Abito su misura', from: 0.65, to: 0.95, x: 22, y: 52 },
  { id: 'modifiche', service: 'Modifiche sartoriali', from: 0.7, to: 0.95, x: 42, y: 58 },
  { id: 'tessuti', service: 'Consulenza tessuti', from: 0.7, to: 0.95, x: 60, y: 62 },
  { id: 'restauro', service: 'Restauro capi', from: 0.65, to: 0.95, x: 78, y: 56 },
];
---

<section class:list={['atelier-hero', className]} data-atelier-hero>
  <div class="atelier-hero__sticky">
    <canvas class="atelier-hero__canvas" data-atelier-canvas></canvas>

    <!-- Hotspot overlay layer. Each hotspot is a button positioned in
         percentage units; JS toggles visibility based on scroll range. -->
    <div class="atelier-hero__hotspots" data-atelier-hotspots>
      {HOTSPOTS.map((h) => (
        <button
          class="hotspot"
          type="button"
          data-hotspot-id={h.id}
          data-hotspot-from={h.from}
          data-hotspot-to={h.to}
          style={`--hx: ${h.x}%; --hy: ${h.y}%`}
          aria-label={h.service}
        >
          <span class="hotspot__ring"></span>
          <span class="hotspot__dot"></span>
          <span class="hotspot__label">{h.service}</span>
        </button>
      ))}
    </div>

    <!-- Progress indicator -- subtle line at bottom. -->
    <div class="atelier-hero__progress" data-atelier-progress></div>
  </div>
</section>

<script define:vars={{ FRAME_COUNT, BASE }}>
  const FRAME_DIR = `${BASE}scenes/atelier-frames/`;
  const SECTION_HEIGHT_MULT = 4; // section is 4x viewport height -> 3x scroll = full scrub

  let images = [];
  let ctx = null;
  let canvas = null;
  let section = null;
  let progressEl = null;
  let hotspots = [];
  let loadedCount = 0;
  let currentFrame = -1;
  let rafPending = false;
  let scrollListener = null;
  let resizeListener = null;

  function pad4(n) {
    return String(n).padStart(4, '0');
  }

  function sizeCanvas() {
    if (!canvas) return;
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    const w = canvas.clientWidth;
    const h = canvas.clientHeight;
    canvas.width = Math.floor(w * dpr);
    canvas.height = Math.floor(h * dpr);
  }

  function drawFrame(idx) {
    if (!ctx || !canvas) return;
    const img = images[idx];
    if (!img || !img.complete || img.naturalWidth === 0) return;
    // object-fit: cover manually
    const cw = canvas.width;
    const ch = canvas.height;
    const iw = img.naturalWidth;
    const ih = img.naturalHeight;
    const canvasRatio = cw / ch;
    const imgRatio = iw / ih;
    let dw, dh, dx, dy;
    if (imgRatio > canvasRatio) {
      // image wider than canvas -- fit height, crop sides
      dh = ch;
      dw = ch * imgRatio;
      dx = (cw - dw) / 2;
      dy = 0;
    } else {
      dw = cw;
      dh = cw / imgRatio;
      dx = 0;
      dy = (ch - dh) / 2;
    }
    ctx.drawImage(img, dx, dy, dw, dh);
  }

  function computeProgress() {
    if (!section) return 0;
    const rect = section.getBoundingClientRect();
    const vh = window.innerHeight;
    const total = rect.height - vh;
    const scrolled = -rect.top;
    return Math.max(0, Math.min(1, scrolled / total));
  }

  function updateHotspots(progress) {
    for (const h of hotspots) {
      const active = progress >= h.from && progress <= h.to;
      h.el.classList.toggle('is-visible', active);
      // Fade in within first 15% of range, fade out within last 15%
      const range = h.to - h.from;
      const local = (progress - h.from) / range;
      let opacity = 0;
      if (active) {
        if (local < 0.15) opacity = local / 0.15;
        else if (local > 0.85) opacity = (1 - local) / 0.15;
        else opacity = 1;
      }
      h.el.style.opacity = String(opacity);
    }
  }

  function tick() {
    rafPending = false;
    const progress = computeProgress();
    // Reverse playback: scroll=0 -> last frame, scroll=1 -> first frame.
    const frameIdx = Math.max(
      0,
      Math.min(FRAME_COUNT - 1, Math.round((1 - progress) * (FRAME_COUNT - 1))),
    );
    if (frameIdx !== currentFrame) {
      drawFrame(frameIdx);
      currentFrame = frameIdx;
    }
    updateHotspots(progress);
    if (progressEl) {
      progressEl.style.transform = `scaleX(${progress})`;
    }
  }

  function onScroll() {
    if (rafPending) return;
    rafPending = true;
    requestAnimationFrame(tick);
  }

  function preload() {
    images = new Array(FRAME_COUNT);
    for (let i = 0; i < FRAME_COUNT; i++) {
      const img = new Image();
      img.src = `${FRAME_DIR}${pad4(i + 1)}.jpg`;
      img.decoding = 'async';
      img.onload = () => {
        loadedCount++;
        if (loadedCount === 1) {
          // First frame loaded -- draw something instead of black.
          tick();
        }
      };
      images[i] = img;
    }
  }

  function init() {
    section = document.querySelector('[data-atelier-hero]');
    canvas = document.querySelector('[data-atelier-canvas]');
    progressEl = document.querySelector('[data-atelier-progress]');
    if (!section || !canvas) return;

    ctx = canvas.getContext('2d');
    sizeCanvas();

    // Collect hotspots into a friendly data shape
    hotspots = Array.from(
      document.querySelectorAll('[data-hotspot-id]'),
    ).map((el) => ({
      el,
      id: el.dataset.hotspotId,
      from: parseFloat(el.dataset.hotspotFrom),
      to: parseFloat(el.dataset.hotspotTo),
    }));

    // Click -> dispatch custom event for side-panel system
    for (const h of hotspots) {
      h.el.addEventListener('click', () => {
        window.dispatchEvent(
          new CustomEvent('atelier-service-open', { detail: { id: h.id } }),
        );
      });
    }

    preload();

    scrollListener = onScroll;
    resizeListener = () => {
      sizeCanvas();
      currentFrame = -1; // force redraw at new size
      tick();
    };
    window.addEventListener('scroll', scrollListener, { passive: true });
    window.addEventListener('resize', resizeListener, { passive: true });

    tick();
  }

  function teardown() {
    if (scrollListener) window.removeEventListener('scroll', scrollListener);
    if (resizeListener) window.removeEventListener('resize', resizeListener);
    images = [];
    ctx = null;
    canvas = null;
    section = null;
    hotspots = [];
    loadedCount = 0;
    currentFrame = -1;
  }

  document.addEventListener('astro:page-load', () => {
    if (document.querySelector('[data-atelier-hero]')) {
      init();
    } else {
      teardown();
    }
  });

  document.addEventListener('astro:before-swap', () => {
    teardown();
  });

  if (document.readyState === 'complete' && document.querySelector('[data-atelier-hero]')) {
    init();
  }
</script>

<style>
  .atelier-hero {
    /* Tall scroll section -- sticky canvas inside scrubs as you scroll */
    position: relative;
    height: 400vh;
    width: 100%;
    background: #1a1414; /* warm dark, in case frames haven't loaded */
  }

  .atelier-hero__sticky {
    position: sticky;
    top: 0;
    width: 100%;
    height: 100vh;
    height: 100svh;
    overflow: hidden;
  }

  .atelier-hero__canvas {
    width: 100%;
    height: 100%;
    display: block;
  }

  /* ---- Hotspots ---- */
  .atelier-hero__hotspots {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hotspot {
    position: absolute;
    left: var(--hx);
    top: var(--hy);
    transform: translate(-50%, -50%);
    width: 44px;
    height: 44px;
    background: transparent;
    border: none;
    cursor: pointer;
    pointer-events: auto;
    padding: 0;
    opacity: 0;
    transition: opacity 0.4s ease;
    will-change: opacity;
  }

  .hotspot.is-visible {
    pointer-events: auto;
  }

  .hotspot:not(.is-visible) {
    pointer-events: none;
  }

  .hotspot__ring {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 1px solid rgba(255, 240, 220, 0.7);
    animation: hotspot-pulse 2.5s ease-in-out infinite;
  }

  .hotspot__dot {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: rgba(255, 240, 220, 0.95);
    transform: translate(-50%, -50%);
    box-shadow: 0 0 12px rgba(255, 200, 150, 0.7);
  }

  .hotspot__label {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(6px);
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255, 240, 220, 0.95);
    white-space: nowrap;
    text-shadow: 0 1px 12px rgba(0, 0, 0, 0.6);
    padding: 4px 8px;
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }

  .hotspot:hover .hotspot__label,
  .hotspot:focus-visible .hotspot__label {
    opacity: 1;
  }

  .hotspot:hover .hotspot__dot,
  .hotspot:focus-visible .hotspot__dot {
    background: rgba(255, 210, 170, 1);
    box-shadow: 0 0 20px rgba(255, 180, 130, 0.9);
  }

  @keyframes hotspot-pulse {
    0%, 100% {
      transform: scale(1);
      opacity: 0.7;
    }
    50% {
      transform: scale(1.35);
      opacity: 0;
    }
  }

  /* ---- Progress bar ---- */
  .atelier-hero__progress {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 2px;
    background: rgba(255, 240, 220, 0.5);
    transform-origin: left center;
    transform: scaleX(0);
    will-change: transform;
  }
</style>
