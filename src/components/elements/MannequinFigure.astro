---
import { MANNEQUIN_SVG } from '../../scripts/mannequin-svg';

interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<div class:list={['mannequin-figure', className]} data-mannequin-figure set:html={MANNEQUIN_SVG} />

<style>
  .mannequin-figure {
    position: relative;
    display: inline-block;
    color: var(--color-fg);
    line-height: 0;
  }

  .mannequin-figure :global(.mannequin-svg) {
    display: block;
    height: 100%;
    width: auto;          /* derived from the viewBox aspect */
    max-height: 100%;
    overflow: visible;
  }
</style>
