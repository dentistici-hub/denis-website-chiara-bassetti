---
interface Props {
  number: string;
  title: string;
  tag: string;
  image: string;
  class?: string;
  size?: 'small' | 'medium' | 'large';
}

const { number, title, tag, image, class: className = '', size = 'medium' } = Astro.props;
---

<article class:list={['portfolio-item', `portfolio-item--${size}`, className]}>
  <div class="portfolio-item__img-wrap" data-clip-reveal="center">
    <img src={image} alt={title} class="portfolio-item__img" loading="lazy" decoding="async" />
  </div>
  <div class="portfolio-item__info">
    <span class="portfolio-item__number">{number}</span>
    <h3 class="portfolio-item__name">{title}</h3>
    <span class="portfolio-item__tag">{tag}</span>
  </div>
</article>

<style>
  .portfolio-item { position: relative; }

  .portfolio-item__img-wrap {
    width: 100%;
    border-radius: 6px;
    overflow: hidden;
    margin-bottom: var(--space-sm);
    background: var(--color-border);
    transition: background-color var(--duration-slow) var(--ease-in-out);
  }

  .portfolio-item--large .portfolio-item__img-wrap { aspect-ratio: 16 / 10; }
  .portfolio-item--medium .portfolio-item__img-wrap { aspect-ratio: 4 / 3; }
  .portfolio-item--small .portfolio-item__img-wrap { aspect-ratio: 1 / 1; }

  .portfolio-item__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease-out);
  }

  .portfolio-item:hover .portfolio-item__img { transform: scale(1.05); }

  .portfolio-item__info {
    display: flex;
    align-items: baseline;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .portfolio-item__number {
    font-size: var(--text-xs);
    color: var(--color-fg-faint);
    letter-spacing: 0.05em;
    transition: color var(--duration-slow) var(--ease-in-out);
  }

  .portfolio-item:hover .portfolio-item__number { color: var(--color-accent); }

  .portfolio-item__name {
    font-size: var(--text-base);
    font-weight: var(--display-weight);
    font-style: var(--display-style);
    font-family: var(--font-display);
  }

  .portfolio-item__tag {
    font-size: var(--text-xs);
    color: var(--color-fg-faint);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-left: auto;
    transition: color var(--duration-slow) var(--ease-in-out);
  }
</style>
