---
interface Props {
  text: string;
  class?: string;
  repeat?: number;
}

const { text, class: className = '', repeat = 8 } = Astro.props;
const repeated = Array.from({ length: repeat }, () => text).join(' \u2014 ');
---

<div class:list={['marquee-strip', className]} aria-hidden="true">
  <div class="marquee-strip__track">
    <span class="marquee-strip__text">{repeated} &mdash;&nbsp;</span>
    <span class="marquee-strip__text">{repeated} &mdash;&nbsp;</span>
  </div>
</div>

<style>
  .marquee-strip {
    overflow: hidden;
    white-space: nowrap;
    padding: var(--space-md) 0;
    transform: rotate(-2deg);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    transition: border-color var(--duration-slow) var(--ease-in-out);
  }

  .marquee-strip__track {
    display: flex;
    width: max-content;
    animation: marquee-scroll 30s linear infinite;
  }

  .marquee-strip__text {
    font-size: var(--text-lg);
    font-family: var(--font-display);
    font-weight: var(--display-weight);
    font-style: var(--display-style);
    letter-spacing: var(--display-spacing);
    text-transform: uppercase;
    color: var(--color-fg-faint);
    transition: color var(--duration-slow) var(--ease-in-out);
  }

  @keyframes marquee-scroll {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
</style>
