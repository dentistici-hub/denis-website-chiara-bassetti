---
interface Props {
  class?: string;
  size?: number;
}
const { class: className = '', size = 16 } = Astro.props;
---
<svg class:list={['deco deco--button', className]} width={size} height={size} viewBox="0 0 16 16" aria-hidden="true" data-cursor-react>
  <circle cx="8" cy="8" r="7" fill="none" stroke="var(--color-stitch)" stroke-width="0.8" />
  <circle cx="6" cy="6" r="1" fill="var(--color-stitch)" />
  <circle cx="10" cy="6" r="1" fill="var(--color-stitch)" />
  <circle cx="6" cy="10" r="1" fill="var(--color-stitch)" />
  <circle cx="10" cy="10" r="1" fill="var(--color-stitch)" />
</svg>
