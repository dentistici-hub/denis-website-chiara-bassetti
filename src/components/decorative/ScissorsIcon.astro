---
interface Props {
  class?: string;
  size?: number;
}
const { class: className = '', size = 28 } = Astro.props;
---
<svg class:list={['deco deco--scissors', className]} width={size} height={size} viewBox="0 0 28 28" aria-hidden="true" data-cursor-react>
  <circle cx="7" cy="21" r="4" fill="none" stroke="var(--color-stitch)" stroke-width="1" />
  <circle cx="21" cy="21" r="4" fill="none" stroke="var(--color-stitch)" stroke-width="1" />
  <line x1="10" y1="18" x2="18" y2="4" stroke="var(--color-stitch)" stroke-width="1" stroke-linecap="round" />
  <line x1="18" y1="18" x2="10" y2="4" stroke="var(--color-stitch)" stroke-width="1" stroke-linecap="round" />
</svg>
